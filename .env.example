# ============================================
# AI Crypto Trading Bot - Configuration
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# Trading Mode: "paper" (simulated) or "live" (real money)
TRADING_MODE=paper

# ── Binance API ──────────────────────────────
# Get your API keys from: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here
BINANCE_TESTNET=true

# ── Telegram Bot ─────────────────────────────
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
# Comma-separated Telegram channel usernames to follow for signals
TELEGRAM_SIGNAL_CHANNELS=

# ── Trading Parameters ───────────────────────
DEFAULT_TRADE_AMOUNT_USDT=100
MAX_POSITIONS=5
MAX_POSITION_SIZE_PCT=10
DAILY_LOSS_LIMIT_PCT=5
STOP_LOSS_PCT=3
TAKE_PROFIT_PCT=6
TRAILING_STOP_PCT=2

# ── AI Trading ───────────────────────────────
AI_CONFIDENCE_THRESHOLD=0.7
AI_RETRAIN_HOURS=24
AI_LOOKBACK_DAYS=30
AI_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT,BNB/USDT
AI_TIMEFRAMES=1h,4h

# ── Copy Trading ─────────────────────────────
# Comma-separated trader IDs/UIDs to copy from Binance leaderboard
COPY_TRADER_IDS=
COPY_TRADE_RATIO=0.1
COPY_POLL_INTERVAL_SEC=30

# ── Dashboard ────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080
DASHBOARD_SECRET_KEY=change_this_to_a_random_secret_key

# ── Database ─────────────────────────────────
DATABASE_URL=sqlite:///trading_bot.db

# ── Security ─────────────────────────────────
# Auto-generated on first run if empty. Keep this safe!
# Generate manually: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ============================================
# AI Healthcare Management Platform
# ============================================
# Start the platform: python -m healthcare.main
# Docs: http://localhost:8090/docs

# ── Healthcare App ────────────────────────────────────────
HEALTHCARE_DATABASE_URL=sqlite:///healthcare.db
HEALTHCARE_HOST=0.0.0.0
HEALTHCARE_PORT=8090
HEALTHCARE_SECRET_KEY=change-this-to-a-strong-random-key
HEALTHCARE_DEBUG=false
HEALTHCARE_BASE_URL=http://localhost:8090

# ── JWT ───────────────────────────────────────────────────
JWT_EXPIRE_MINUTES=60

# ── OpenAI (AI triage & 24/7 assistant) ──────────────────
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ── Redis & Celery (24/7 background workflows) ────────────
# Install Redis: https://redis.io/docs/getting-started/
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Stripe (medical bill payments) ───────────────────────
# Get your keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# ── Twilio (SMS appointment reminders) ───────────────────
# Sign up at: https://www.twilio.com/
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+15005550006

# ── SendGrid (email notifications) ───────────────────────
# Sign up at: https://sendgrid.com/
SENDGRID_API_KEY=your_sendgrid_api_key
FROM_EMAIL=noreply@yourhealthcare.com
FROM_NAME=HealthCare+ Platform
